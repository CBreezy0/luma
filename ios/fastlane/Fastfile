default_platform(:ios)

platform :ios do
  desc "Build an App Store archive and upload it to TestFlight (manual use only)"
  lane :beta do
    # This lane is intentionally guarded for manual distribution only.
    unless ENV.fetch("CONFIRM_TESTFLIGHT_UPLOAD", "false") == "true"
      UI.user_error!(
        "Refusing to upload. Set CONFIRM_TESTFLIGHT_UPLOAD=true for an intentional TestFlight run."
      )
    end

    distribute_external = ENV.fetch("TESTFLIGHT_DISTRIBUTE_EXTERNAL", "false") == "true"
    notify_external_testers = ENV.fetch("TESTFLIGHT_NOTIFY_EXTERNAL_TESTERS", "false") == "true"
    groups = ENV.fetch("TESTFLIGHT_GROUPS", "")
      .split(",")
      .map(&:strip)
      .reject(&:empty?)
    changelog = ENV["TESTFLIGHT_CHANGELOG"]

    cocoapods(clean_install: true)

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        method: "app-store-connect",
        manageAppVersionAndBuildNumber: false,
        signingStyle: "automatic",
        stripSwiftSymbols: true,
        teamID: ENV["APPLE_TEAM_ID"],
        uploadSymbols: true,
        testFlightInternalTestingOnly: false
      }
    )

    upload_options = {
      skip_waiting_for_build_processing: false,
      distribute_external: distribute_external,
      changelog: changelog
    }

    upload_options[:notify_external_testers] = notify_external_testers if distribute_external
    upload_options[:groups] = groups unless groups.empty?

    upload_to_testflight(**upload_options)
  end
end
